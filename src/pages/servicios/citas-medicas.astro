---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";

// 1. Array de Módulos Médicos
const modules = [
  { id: "dashboard", title: "Dashboard", description: "Métricas de pacientes y flujo de caja diario.", icono: "monitor-heart", price: 0 },
  { id: "agenda", title: "Agenda Inteligente", description: "Control de citas, cancelaciones y reprogramaciones.", icono: "calendar-days", price: 100 },
  { id: "expediente", title: "Expediente Clínico", description: "Historial médico (ECE) seguro y en la nube.", icono: "folder-open", price: 150 },
  { id: "recetas", title: "Recetas Electrónicas", description: "Generación de recetas con base de datos de medicamentos.", icono: "document-text", price: 80 },
  { id: "facturacion", title: "Caja y Facturación", description: "Cobro de consultas, aseguradoras y facturación.", icono: "banknotes", price: 100 },
  { id: "recordatorios", title: "Recordatorios WhatsApp", description: "Notificaciones automáticas para reducir ausentismo.", icono: "chat-bubble-left-ellipsis", price: 70 },
  { id: "portal_paciente", title: "Portal del Paciente", description: "Los pacientes pueden agendar sus propias citas online.", icono: "globe-alt", price: 120 },
  { id: "telemedicina", title: "Telemedicina", description: "Módulo de videoconsultas integrado y seguro.", icono: "video-camera", price: 150 },
  { id: "inventario_farmacia", title: "Farmacia / Inventario", description: "Control de stock de insumos médicos y medicamentos.", icono: "medication", price: 120 },
  { id: "laboratorio", title: "Laboratorio e Imagen", description: "Carga y visualización de resultados de estudios.", icono: "beaker", price: 100 },
  { id: "usuarios_roles", title: "Roles de Personal", description: "Accesos para asistentes, enfermeras y médicos.", icono: "shield-check", price: 80 },
  { id: "multi_sucursal", title: "Multi-Consultorio", description: "Gestión de varias sucursales o pisos médicos.", icono: "building-office-2", price: 120 },
  { id: "reportes", title: "Reportes Epidemiológicos", description: "Estadísticas avanzadas y reportes de salud.", icono: "chart-pie", price: 150 },
];

const pricingPlans = [
  {
    tag: "01 / CONSULTORIO",
    name: "MÉDICO TITULAR",
    monthlyPrice: 290,
    yearlyPrice: 230,
    isPopular: false,
    features: [
      "1 Médico / 1 Asistente",
      "Agenda y Gestión de Citas",
      "Expediente Clínico Electrónico",
      "Recetas Electrónicas",
      "Soporte por correo electrónico"
    ],
    buttonText: "Seleccionar",
    style: "secondary",
  },
  {
    tag: "02 / CLÍNICA",
    name: "CLÍNICA PRO",
    monthlyPrice: 550,
    yearlyPrice: 440,
    isPopular: true,
    features: [
      "Hasta 5 Médicos y Personal",
      "Recordatorios por WhatsApp",
      "Portal de Auto-agendado",
      "Caja, Facturación y Aseguradoras",
      "Laboratorio e Imagen básica",
      "Soporte prioritario"
    ],
    buttonText: "Comenzar Ahora",
    style: "primary",
  },
  {
    tag: "03 / HOSPITAL",
    name: "RED MÉDICA MASTER",
    monthlyPrice: 1200, 
    yearlyPrice: 960,
    isPopular: false,
    features: [
      "Médicos y Sucursales ilimitadas",
      "Módulo de Telemedicina",
      "Farmacia y Control de Insumos",
      "Reportes Epidemiológicos Avanzados",
      "Auditoría de Expedientes (NOM)",
      "Soporte 24/7 y Capacitación"
    ],
    buttonText: "Seleccionar",
    style: "secondary",
  },
];
---

<Layout title="Gestión Médica | MEDISOFT">
  <Navbar />
  
  <div x-data="{ 
    isYearly: false, 
    selectedModules: [], 
    showAlert: false,
    alertPlanName: '',
    proAlertShown: false,
    masterAlertShown: false,
    
    toggleModule(id) {
      if (this.selectedModules.includes(id)) {
        this.selectedModules = this.selectedModules.filter(m => m !== id);
      } else {
        this.selectedModules.push(id);
        
        let total = this.currentTotal;
        
        // Alerta escalable: Sugerir MASTER si pasa los $1200, o PRO si pasa los $550
        if (total >= 1200 && !this.masterAlertShown) {
          this.alertPlanName = 'RED MÉDICA MASTER';
          this.showAlert = true;
          this.masterAlertShown = true;
        } else if (total >= 550 && total < 1200 && !this.proAlertShown) {
          this.alertPlanName = 'CLÍNICA PRO';
          this.showAlert = true;
          this.proAlertShown = true;
        }
      }
    },
    get currentTotal() {
      // Diccionario de precios de los módulos médicos
      const precios = {
        dashboard: 0, agenda: 100, expediente: 150, recetas: 80, facturacion: 100,
        recordatorios: 70, portal_paciente: 120, telemedicina: 150, inventario_farmacia: 120,
        laboratorio: 100, usuarios_roles: 80, multi_sucursal: 120, reportes: 150
      };
      return this.selectedModules.reduce((sum, id) => sum + (precios[id] || 0), 0);
    }
  }" class="min-h-screen pt-20">

    <div 
      x-show="showAlert" 
      x-transition.opacity
      class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4"
      x-cloak
    >
      <div @click.away="showAlert = false" class="bg-[var(--color-surface-container-low)] border border-primary/30 p-8 max-w-md w-full text-center rounded-none shadow-2xl">
        <span class="material-symbols-outlined text-primary text-5xl mb-4">health_and_safety</span>
        <h3 class="font-headline-md text-xl uppercase mb-2 text-white">¡Optimiza tu Inversión!</h3>
        <p class="font-body-md text-on-surface-variant mb-6 text-sm">
          Tu selección de módulos está alcanzando el costo del plan <strong class="text-primary" x-text="alertPlanName"></strong>. Te recomendamos revisar nuestros planes fijos para obtener funciones para múltiples médicos y soporte clínico avanzado sin costo extra.
        </p>
        <div class="flex flex-col gap-2">
          <button @click="showAlert = false" class="bg-primary text-[var(--color-surface)] py-3 font-label-caps text-xs uppercase hover:opacity-90 transition-all">
            Seguir con mi plan a medida
          </button>
          <button @click="showAlert = false; document.getElementById('pricing-section').scrollIntoView({behavior: 'smooth'})" class="border border-white/20 hover:bg-white hover:text-black py-3 font-label-caps text-xs uppercase transition-all">
            Ver planes estructurados
          </button>
        </div>
      </div>
    </div>
    
    <main>
      <section class="relative pt-32 pb-20 px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto overflow-hidden">
        <div class="absolute -top-20 -right-20 w-96 h-96 bg-primary/5 blur-[120px] rounded-full"></div>

        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
          <div class="max-w-4xl">
            <span class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant mb-4 block">
              SOLUCIONES DE SALUD DIGITAL / {new Date().getFullYear()}
            </span>
            <h1 class="font-display-lg text-[length:var(--text-display-lg-mobile)] md:text-[length:var(--text-display-lg)] uppercase leading-none">
              GESTIÓN CLÍNICA &amp;<br />EXPEDIENTE MÉDICO
            </h1>
          </div>

          <div class="max-w-xs text-right hidden md:block">
            <p class="font-body-md text-[length:var(--text-body-md)] text-on-surface-variant">
              SOFTWARE MÉDICO INTEGRAL DISEÑADO PARA OPTIMIZAR LA ATENCIÓN AL PACIENTE Y ESCALAR TU PRÁCTICA PROFESIONAL.
            </p>
          </div>
        </div>
      </section>

      <section id="pricing-section" class="px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto mb-40">
        
        <div class="flex justify-center mb-16">
          <div class="flex items-center gap-4 bg-[var(--color-surface-container-low)] p-2 rounded-lg border border-white/5">
            <span class="font-label-caps text-[length:var(--text-label-caps)]" :class="!isYearly ? 'text-primary' : 'text-on-surface-variant'">
              MENSUAL
            </span>

            <label class="relative inline-flex items-center cursor-pointer">
              <input type="checkbox" x-model="isYearly" class="sr-only peer" />
              <div class="w-11 h-6 bg-[var(--color-surface-variant)] rounded-full peer-checked:bg-primary transition-colors"></div>
              <div class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform" :class="isYearly ? 'translate-x-5' : ''"></div>
            </label>

            <span class="font-label-caps text-[length:var(--text-label-caps)]" :class="isYearly ? 'text-primary' : 'text-on-surface-variant'">
              ANUAL (SAVE 20%)
            </span>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-[1px] bg-white/10 border border-white/10">
          {pricingPlans.map((plan) => (
            <div
              class={`p-12 flex flex-col h-full transition-colors relative overflow-hidden 
                ${plan.style === 'primary' ? 'bg-[var(--color-surface-container-low)] hover:bg-[var(--color-surface-container)]' : 'bg-[var(--color-surface)] border-r border-white/5 md:border-r-0 hover:bg-[#1a1a1a]'}`}
            >
              {plan.isPopular && (
                <div class="absolute top-0 right-0 bg-primary text-[var(--color-surface)] px-4 py-1 font-label-caps text-[10px]">
                  MÁS ELEGIDO
                </div>
              )}

              <span class={`font-label-caps text-[length:var(--text-label-caps)] mb-2 ${plan.style === 'primary' ? 'text-primary' : 'text-on-surface-variant'}`}>
                {plan.tag}
              </span>
              <h3 class="font-headline-md text-[length:var(--text-headline-md)] mb-8 uppercase">
                {plan.name}
              </h3>

              <div class="text-[length:var(--text-display-lg-mobile)] font-headline-md mb-8">
                <span x-text={`isYearly ? '$${plan.yearlyPrice}' : '$${plan.monthlyPrice}'`}>
                  ${plan.monthlyPrice}
                </span>
                <span class="text-[length:var(--text-label-caps)] text-on-surface-variant font-body-md">/MES</span>
              </div>

              <ul class={`space-y-4 mb-12 flex-grow font-body-md text-[length:var(--text-body-md)] ${plan.style === 'primary' ? 'text-on-surface' : 'text-on-surface-variant'}`}>
                {plan.features.map((feature) => (
                  <li class="flex items-center gap-2">
                    <span class={`material-symbols-outlined text-sm ${plan.style === 'primary' ? 'text-primary' : ''}`}>
                      check
                    </span> 
                    {feature}
                  </li>
                ))}
              </ul>

              <button
                class={`w-full py-4 font-label-caps text-[length:var(--text-label-caps)] transition-all uppercase 
                  ${plan.style === 'primary' ? 'bg-primary text-[var(--color-surface)] hover:opacity-90' : 'border border-white/20 hover:bg-white hover:text-black'}`}
              >
                {plan.buttonText}
              </button>
            </div>
          ))}
        </div>
      </section>

      <section class="px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] py-32 max-w-[var(--spacing-container-max)] mx-auto border-t border-white/10">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-8">
          <div>
            <h2 class="font-headline-lg text-[length:var(--text-headline-lg)] mb-4 uppercase">
              CONSULTORIO A MEDIDA
            </h2>
            <p class="font-body-lg text-[length:var(--text-body-lg)] text-on-surface-variant max-w-lg">
              DISEÑA TU ECOSISTEMA CLÍNICO SELECCIONANDO ÚNICAMENTE LAS HERRAMIENTAS QUE TU PRÁCTICA NECESITA.
            </p>
          </div>
          <div class="flex items-center gap-4 border border-white/10 p-4">
            <span class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant">
              TOTAL ESTIMADO:
            </span>
            <span
              class="font-headline-md text-[length:var(--text-headline-md)] transition-transform duration-200"
              :class="currentTotal > 0 ? 'scale-110 text-primary' : ''"
              x-text="`$${currentTotal}`"
            >$0</span>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-4 gap-[var(--spacing-gutter)]">
          {modules.map((module) => (
            <div
              @click={`toggleModule('${module.id}')`}
              :class={`selectedModules.includes('${module.id}') ? 'border-primary bg-[var(--color-surface-container-low)]' : 'border border-white/10'`}
              class="p-8 hover:border-white/50 hover:bg-[#1a1a1a] transition-all cursor-pointer group"
            >
              <div class="flex justify-between mb-8">
                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">
                 
                </span>
                <span class="font-label-caps text-[length:var(--text-label-caps)] opacity-40">
                  + ${module.price}
                </span>
              </div>
              <h3 class="font-headline-md text-[length:var(--text-headline-md)] mb-4 uppercase">
                {module.title}
              </h3>
              <p class="font-body-md text-[length:var(--text-body-md)] text-on-surface-variant mb-8">
                {module.description}
              </p>
              <div class="flex justify-between items-center">
                <span x-text={`selectedModules.includes('${module.id}') ? 'SELECCIONADO' : 'AÑADIR'`} class="font-label-caps text-[length:var(--text-label-caps)]">
                  AÑADIR
                </span>
                <span x-show={`selectedModules.includes('${module.id}')`} class="material-symbols-outlined text-primary" x-cloak>
                  check_circle
                </span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="mb-40 px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)]">
        <div class="max-w-[var(--spacing-container-max)] mx-auto bg-primary text-[var(--color-surface)] p-20 text-center relative overflow-hidden">
          <h2 class="font-display-lg-mobile md:font-display-lg text-[length:var(--text-display-lg-mobile)] md:text-[length:var(--text-display-lg)] mb-12 uppercase relative z-10">
            DIGITALIZA TU PRÁCTICA HOY
          </h2>
          <button class="bg-[var(--color-surface)] text-primary px-12 py-6 font-label-caps text-[length:var(--text-label-caps)] uppercase hover:opacity-90 transition-all active:scale-95 relative z-10">
            Agendar Demo Clínica
          </button>
        </div>
      </section>

    </main>
  </div>
  
  <Footer />
</Layout>

<style>
  [x-cloak] { display: none !important; }
</style>