---
// src/components/Navbar.astro

const services = [
  {
    title: "Desarrollo Web",
    href: "/servicios/desarrollo-web",
    icon: "language",
  },
  {
    title: "Inventario / POS",
    href: "/servicios/inventario-pos",
    icon: "inventory_2",
  },
  //{
  //  title: "Citas Médicas",
  //  href: "/servicios/citas-medicas",
  //  icon: "medical_services",
  //},
  //{
  //  title: "Citas Veterinarias",
  //  href: "/servicios/citas-veterinarias",
  //  icon: "pets",
  //},
  //{
  //  title: "Restaurantes",
  //  href: "/servicios/gestion-restaurantes",
  //  icon: "restaurant",
  //},
  //{
  //  title: "Citas Generales",
  //  href: "/servicios/citas-generales",
  //  icon: "all_inclusive",
  //},
  //{
  //  title: "Sistemas de Citas",
  //  href: "/servicios/sistemas-de-citas",
  //  icon: "calendar_month",
  //},
];

const countServices = services.length;
---

<nav
  x-data="{ mobileMenuOpen: false, servicesOpen: false }"
  class="fixed top-0 left-0 w-full z-50 backdrop-blur-[20px] bg-[var(--color-surface)]/80 border-b border-white/10"
>
  <div
    class="flex justify-between items-center h-20 px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto w-full"
  >
    <a
      href="/"
      class="font-headline-md text-[length:var(--text-headline-md)] tracking-tighter text-primary hover:opacity-80 transition-opacity"
    >
      LUNAWEB
    </a>

    <!-- Desktop Menu -->
    <div class="hidden md:flex items-center space-x-8">
      <!-- Services Dropdown -->
      <div
        class="relative"
        x-data="{ open: false }"
        @mouseenter="open = true"
        @mouseleave="open = false"
      >
        <button
          class="font-label-caps text-[length:var(--text-label-caps)] text-primary border-b border-primary pb-1 flex items-center gap-1"
          @click="open = !open"
        >
          SERVICIOS
          <span
            class="material-symbols-outlined text-sm transition-transform duration-200"
            :class="open ? 'rotate-180' : ''">expand_more</span
          >
        </button>

        <!-- Dropdown Panel -->
        <div
          x-show="open"
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          x-transition:leave="transition ease-in duration-150"
          x-transition:leave-start="opacity-100 translate-y-0"
          x-transition:leave-end="opacity-0 translate-y-2"
          class="absolute top-full left-1/2 -translate-x-1/2 mt-4 w-[480px] bg-[#0e0e0e] border border-white/10 shadow-2xl"
          style="display: none;"
        >
          <div class="p-2 grid grid-cols-2 gap-px bg-white/5">
            {
              services.map((s) => (
                <a
                  href={s.href}
                  class="flex items-center gap-3 p-4 bg-[#131313] hover:bg-[#1a1a1a] group transition-colors"
                >
                  <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors text-[20px]">
                    {s.icon}
                  </span>
                  <span class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant group-hover:text-primary transition-colors">
                    {s.title}
                  </span>
                </a>
              ))
            }
          </div>
          <div
            class="p-4 border-t border-white/5 flex justify-between items-center"
          >
            <span
              class="font-label-caps text-[10px] text-on-surface-variant tracking-widest"
              >{countServices} SOLUCIONES DISPONIBLES</span
            >
            <a
              href="/#services"
              class="font-label-caps text-[10px] text-primary hover:underline tracking-widest"
              >VER TODAS →</a
            >
          </div>
        </div>
      </div>

      <a
        class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant hover:text-primary transition-colors"
        href="#">NOSOTROS</a
      >
      <a
        class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant hover:text-primary transition-colors"
        href="#">CONTACTO</a
      >
    </div>

    <div class="hidden md:block">
      <button
        class="bg-primary text-on-primary px-6 py-2 font-label-caps text-[length:var(--text-label-caps)] hover:opacity-80 transition-opacity active:scale-95 duration-150"
      >
        GET STARTED
      </button>
    </div>

    <!-- Mobile Menu Button -->
    <button
      @click="mobileMenuOpen = !mobileMenuOpen"
      class="md:hidden text-primary p-2"
    >
      <span
        class="material-symbols-outlined text-3xl"
        x-text="mobileMenuOpen ? 'close' : 'menu'">menu</span
      >
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    x-show="mobileMenuOpen"
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-4"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-4"
    class="md:hidden absolute top-20 left-0 w-full bg-[#0e0e0e] border-b border-white/10 shadow-xl"
    style="display: none;"
  >
    <!-- Services accordion -->
    <div x-data="{ servicesOpen: false }">
      <button
        @click="servicesOpen = !servicesOpen"
        class="w-full flex justify-between items-center px-4 py-4 font-label-caps text-[length:var(--text-label-caps)] text-primary border-b border-white/5"
      >
        SERVICIOS
        <span
          class="material-symbols-outlined text-sm transition-transform duration-200"
          :class="servicesOpen ? 'rotate-180' : ''">expand_more</span
        >
      </button>
      <div
        x-show="servicesOpen"
        x-transition
        class="bg-[#131313]"
        style="display: none;"
      >
        {
          services.map((s) => (
            <a
              href={s.href}
              class="flex items-center gap-3 px-6 py-3 border-b border-white/5 hover:bg-[#1a1a1a] group transition-colors"
            >
              <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors text-[18px]">
                {s.icon}
              </span>
              <span class="font-label-caps text-[11px] text-on-surface-variant group-hover:text-primary tracking-widest">
                {s.title}
              </span>
            </a>
          ))
        }
      </div>
    </div>

    <a
      class="block px-4 py-4 font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant border-b border-white/5"
      href="#">NOSOTROS</a
    >
    <a
      class="block px-4 py-4 font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant border-b border-white/5"
      href="#">CONTACTO</a
    >
    <div class="p-4">
      <button
        class="w-full bg-primary text-on-primary px-6 py-3 font-label-caps text-[length:var(--text-label-caps)]"
      >
        GET STARTED
      </button>
    </div>
  </div>
</nav>
