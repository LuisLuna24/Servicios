---
// src/components/Footer.astro
---

<footer class="border-t border-white/10 bg-[var(--color-surface)]">
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center py-20 px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto w-full gap-12">
    <div class="space-y-6">
      <div class="font-headline-lg text-[length:var(--text-headline-lg)] text-primary uppercase">LUNAWEB</div>
      <p class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant">© 2024 LUNAWEB. ARCHITECTING DIGITAL EXCELLENCE.</p>
    </div>
    
    <div class="flex flex-wrap gap-8">
      <a class="font-body-md text-[length:var(--text-body-md)] text-on-surface-variant hover:text-primary transition-colors" href="#">LinkedIn</a>
      <a class="font-body-md text-[length:var(--text-body-md)] text-on-surface-variant hover:text-primary transition-colors" href="#">GitHub</a>
      <a class="font-body-md text-[length:var(--text-body-md)] text-on-surface-variant hover:text-primary transition-colors" href="#">Twitter</a>
      <a class="font-body-md text-[length:var(--text-body-md)] text-on-surface-variant hover:text-primary transition-colors" href="#">Email</a>
    </div>
  </div>
</footer>
