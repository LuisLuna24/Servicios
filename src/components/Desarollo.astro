---
// src/components/Services.astro

const services = [
    {
        id: "01",
        icon: "medical_services",
        title: "Citas Médicas",
        description:
            "Flujos de trabajo optimizados para clínicas y especialistas que valoran el tiempo del paciente.",
        // href: "/servicios/citas-medicas", // Comentado o eliminado temporalmente
    },
    {
        id: "02",
        icon: "pets",
        title: "Veterinarias",
        description:
            "Gestión integral de historias clínicas y calendarios de vacunación automatizados.",
    },
    {
        id: "03",
        icon: "restaurant",
        title: "Restaurantes",
        description:
            "Sincronización perfecta entre cocina y sala para una experiencia gastronómica impecable.",
    },
    {
        id: "04",
        icon: "all_inclusive",
        title: "Citas Generales",
        description:
            "Arquitecturas personalizadas para salones, talleres y centros de servicio.",
    },
];
---

<section
    class="py-32 px-[var(--spacing-margin-mobile)] md:px-[var(--spacing-margin-desktop)] max-w-[var(--spacing-container-max)] mx-auto border-t border-white/10"
    id="services"
>
    <div
        class="flex flex-col md:flex-row justify-between items-start md:items-end mb-20 gap-8"
    >
        <div>
            <p
                class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant mb-4"
            >
                NUESTRA EXPERIENCIA
            </p>
            <h2
                class="font-headline-lg text-[length:var(--text-headline-lg)] text-primary uppercase"
            >
                SERVICIOS EN DESARROLLO
            </h2>
        </div>
        <p
            class="font-body-md text-[length:var(--text-body-md)] text-on-surface-variant max-w-xs text-right hidden md:block"
        >
            SOLUCIONES ESCALABLES PARA NEGOCIOS QUE DEMANDAN EXCELENCIA TÉCNICA.
        </p>
    </div>

    <div
        class="grid grid-cols-1 md:grid-cols-3 gap-0 border-t border-l border-white/10"
    >
        {
            services.map((service) => (
                <div class="p-12 border border-white/10 border-t-0 border-l-0 bg-transparent flex flex-col justify-between min-h-[320px]">
                    <div>
                        <div class="flex justify-between items-center mb-8">
                            <span class="font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant">
                                {service.id}
                            </span>
                            <span class="px-3 py-1 bg-white/5 border border-white/10 rounded-full text-[10px] tracking-widest uppercase text-on-surface-variant">
                                En desarrollo
                            </span>
                        </div>

                        <span class="material-symbols-outlined text-on-surface-variant/70 mb-4 block text-3xl">
                            {service.icon}
                        </span>

                        <h3 class="font-headline-md text-[length:var(--text-headline-md)] text-primary/80 mb-4 uppercase">
                            {service.title}
                        </h3>
                        <p class="text-on-surface-variant/80 font-body-md text-[length:var(--text-body-md)] mb-8">
                            {service.description}
                        </p>
                    </div>

                    <div class="flex justify-between items-center space-x-2 font-label-caps text-[length:var(--text-label-caps)] text-on-surface-variant/50 border-b border-white/5 pb-1 mt-auto cursor-default">
                        <span>PRÓXIMAMENTE</span>
                        <span class="material-symbols-outlined text-sm">
                            hourglass_empty
                        </span>
                    </div>
                </div>
            ))
        }
    </div>
</section>
